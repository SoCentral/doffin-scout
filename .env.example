# Kopier denne filen til .env for lokal utvikling
# I Netlify: legg disse inn under Site Settings → Environment Variables

# Doffin Beta API-nøkkel
DOFFIN_API_KEY=din_doffin_subscription_key

# Anthropic API-nøkkel (fra console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Resend API-nøkkel (fra resend.com – gratis inntil 3000 epost/mnd)
RESEND_API_KEY=re_...

# Avsender – må matche et verifisert domene i Resend
EMAIL_FROM=Doffin Scout <scout@socentral.no>

# Mottaker
EMAIL_TO=thomas.evensen@socentral.no
